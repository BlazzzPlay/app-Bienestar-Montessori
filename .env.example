# ============================================
# Bienestar Montessori — Variables de Entorno
# ============================================
# Copiá este archivo a .env.local y completá los valores

# Puerto del servidor de desarrollo
PORT=3000

# URL pública de la aplicación (para redirects de auth)
NEXT_PUBLIC_SITE_URL=https://bienestar.blazz.cl

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Base de datos (a definir según motor elegido)
# DATABASE_URL=postgresql://user:password@localhost:5432/bienestar_montessori

# Auth (a definir según proveedor)
# NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET=generar-con-openssl-rand-base64-32

# Vercel Analytics (opcional — solo en producción)
# NEXT_PUBLIC_VERCEL_ANALYTICS_ID=
